RewriteEngine On

# Якщо точний запит /ua — редірект на /ua/index
RewriteRule ^ua/?$ /ua/index [R=301,L]

# Якщо точний запит /ru — редірект на /ru/index
RewriteRule ^ru/?$ /ru/index [R=301,L]

# 🔁 Редірект з *.html на чистий URL без .html
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.*)\.html$ /$1 [R=301,L]

# ✅ Якщо файл існує з .html — відкриваємо його по чистому URL
#RewriteCond %{REQUEST_FILENAME}.html -f
#RewriteRule ^(.+?)/?$ $1.html [L]

# ✅ Якщо існує файл або папка — показуємо як є
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 🔁 Ручні редіректи
Redirect 301 /org_price.php /ru/prays-orgsteklo
Redirect 301 /org_1.php /ru/orgsteklo
Redirect 301 /kaprolon.php /ru/kaprolon-v-sterzhnyakh
Redirect 301 /tekstolit_1.php /ru/tekstolit

Redirect 301 /index.php /index

Redirect 301 /orgsklo-lysty /ua/prays-orgsteklo
Redirect 301 /lazernaya-rezka-akrila /ru/lazernaya-rezka-akrila
Redirect 301 /rezka-faneri /ru/rezka-faneri
Redirect 301 /laser-gravirovka /ru/laser-gravirovka
Redirect 301 /yslygi /ru/yslygi
Redirect 301 /rule /ru/rule
Redirect 301 /prays-orgsteklo /ru/prays-orgsteklo
Redirect 301 /ftoroplast /ru/ftoroplast
Redirect 301 /tekstolit /ru/tekstolit
Redirect 301 /stellaj-nastenni /ru/stellaj-nastenni
Redirect 301 /price /ru/price

# ❌ 404 сторінка
ErrorDocument 404 /404