# php -- BEGIN cPanel-generated handler, do not edit
<IfModule fcgid_module>
    <IfModule mime_module>
        AddHandler fcgid-script .php .php7 .phtml
        FcgidWrapper /usr/local/cpanel/cgi-sys/ea-php74 .php
        FcgidWrapper /usr/local/cpanel/cgi-sys/ea-php74 .php7
        FcgidWrapper /usr/local/cpanel/cgi-sys/ea-php74 .phtml
    </IfModule>
</IfModule>


# Якщо URL не містить "ua" або "ru" — редирект у /ru/
RewriteCond %{REQUEST_URI} !^/(ua|ru)/ [NC]
RewriteCond %{REQUEST_URI} !\.(css|js|png|jpg|jpeg|gif|svg|webp|woff|woff2|ttf|ico|html)$ [NC]
RewriteRule ^(.*)$ /ru/$1 [R=301,L]

# Старі сторінки .php
Redirect 301 /org_price.php /ru/prays-orgsteklo
Redirect 301 /org_1.php /ru/orgsteklo
Redirect 301 /kaprolon.php /ru/kaprolon-v-sterzhnyakh
Redirect 301 /tekstolit_1.php /ru/tekstolit
Redirect 301 /index.php /ru/

# Сторінка 404
ErrorDocument 404 /404

