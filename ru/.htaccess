RewriteEngine On
DirectoryIndex index index.html

# 🔁 HTTPS редірект
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

# 🔁 Редірект з кореня і /index на /ua
RewriteRule ^$ /ua [R=301,L]
RewriteRule ^index/?$ /ua [R=301,L]

# ✅ Показуємо файл по чистому URL (без редіректу)
RewriteRule ^ua/?$ ua/index [L]
RewriteRule ^ru/?$ ru/index [L]

# ✅ Якщо існує файл або папка — показуємо як є
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Перенаправлення файлів з подвійною двокрапкою в кінці до папки /ru/
RewriteRule ^(.*)::$ /ru/$1 [R=301,L]

# 🔁 Ручні редіректи
